# Vercel → Project → Settings → Environment Variables (Production + Preview)
# Get an API key at https://resend.com — add and verify your sending domain for production.

RESEND_API_KEY=re_xxxxxxxx

# Optional — defaults to MIC Assessment <onboarding@resend.dev> until you verify a domain
# RESEND_FROM=MIC Assessment <notifications@yourdomain.com>

# Optional — defaults to mji@ampcreative.io
# NOTIFY_EMAIL=mji@ampcreative.io
